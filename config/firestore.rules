rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs collection — read-only for any authenticated user
    // (shared/global dedup cache, not per-user data)
    // Only the backend service account writes here (bypasses security rules)
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Search alerts — per-user, scoped by userId
    match /search_alerts/{alertId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // FCM tokens — per-user, scoped by userId
    match /fcm_tokens/{tokenId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Notified jobs — per-user tracking (seen, hidden, notifiedAt)
    // Backend service account writes notifiedAt; frontend writes seen/hidden.
    // Both use merge, so they don't overwrite each other.
    match /notified_jobs/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
